{
    "name": "@unified-calendar/web",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "clean:cache": "rm -rf .turbo",
        "clean:artifacts": "rm -rf .next coverage .turbo tsconfig.tsbuildinfo",
        "clean": "pnpm run clean:artifacts",
        "start": "next start",
        "lint": "biome check src next.config.mjs",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@azure/msal-node": "^5.1.3",
        "@fullcalendar/react": "^6.1.20",
        "@fullcalendar/timegrid": "^6.1.20",
        "googleapis": "^171.4.0",
        "iron-session": "^8.0.4",
        "next": "15.0.4",
        "postgres": "^3.4.9",
        "react": "19.0.0",
        "react-dom": "19.0.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^22.10.1",
        "@types/react": "^19.0.1",
        "@types/react-dom": "^19.0.1",
        "@vitejs/plugin-react": "^4.7.0",
        "@vitest/coverage-v8": "^2.1.8",
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    }
