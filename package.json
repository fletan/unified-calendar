{
    "name": "@unified-calendar/workspace",
    "private": true,
    "version": "0.1.0",
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev --parallel",
        "clean:cache": "turbo run clean:cache && rm -rf .turbo",
        "clean:artifacts": "turbo run clean:artifacts && rm -rf .turbo",
        "clean": "pnpm clean:artifacts && rm -rf node_modules",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "test:coverage": "turbo run test:coverage"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "turbo": "^2.0.14"
    }
}
