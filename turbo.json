{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "clean": {
            "cache": false
        },
        "clean:cache": {
            "cache": false
        },
        "clean:artifacts": {
            "cache": false
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^typecheck"
            ]
        },
        "test": {
            "dependsOn": [
                "^test"
            ]
        },
        "test:coverage": {
            "dependsOn": [
                "^test:coverage"
            ],
            "outputs": [
                "coverage/**"
            ]
        }
    }
}
