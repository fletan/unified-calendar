{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "./base.json",
    "compilerOptions": {
        "jsx": "preserve",
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ES2022"
        ],
        "allowJs": false,
        "incremental": true,
        "isolatedModules": true,
        "noEmit": true,
        "plugins": [
            {
                "name": "next"
            }
        ]
    }
}
