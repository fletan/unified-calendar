{
    "name": "@unified-calendar/ui",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js"
    },
    "scripts": {
        "build": "rm -rf dist && tsc -p tsconfig.json",
        "clean:artifacts": "rm -rf dist coverage .turbo",
        "clean:cache": "rm -rf .turbo",
        "clean": "pnpm run clean:artifacts",
        "lint": "biome check src",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^2.1.8",
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    },
    "dependencies": {
        "@unified-calendar/domain": "workspace:*"
    }
}
